OPENAI_API_KEY=sk-...
# Optional — defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
# Image generation for Creative studio (default dall-e-3)
# OPENAI_IMAGE_MODEL=dall-e-3

# Optional: set to false to persist SQLite + raw_html across backend restarts
# (recommended when using `node --watch`). By default the DB is cleared on each start.
# RESET_DB_ON_START=false

PORT=3001
# Bind to IPv4 so Vite proxy (127.0.0.1) matches — avoids ECONNRESET on Windows
HOST=127.0.0.1
# Optional extra origin (localhost + 127.0.0.1 are allowed by default in dev)
# CORS_ORIGIN=http://localhost:5173
